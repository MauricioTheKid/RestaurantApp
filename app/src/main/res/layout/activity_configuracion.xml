<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#FAFAFA">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FF5722"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        android:elevation="4dp"
        android:titleTextColor="#FFFFFF"
        android:title="Configuración" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗂️ GESTIÓN DE DATOS"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FF5722"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Administra los datos de la aplicación"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnBorrarPedidos"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="🗑️ Borrar Todos los Pedidos"
                android:textSize="14sp"
                android:background="#FF9800"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnReiniciarVentas"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="💰 Reiniciar Ventas"
                android:textSize="14sp"
                android:background="#FF9800"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnBorrarTodo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="⚠️ Borrar TODOS los Datos"
                android:textSize="14sp"
                android:background="#F44336"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ℹ️ Al borrar los datos, se eliminarán pedidos, ventas, productos y usuarios. Los cambios no se pueden deshacer."
                android:textSize="11sp"
                android:textColor="#999999"
                android:textAlignment="center"
                android:layout_marginTop="20dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>